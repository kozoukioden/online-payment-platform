{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "onlinepaymentplatform-clone-perfect/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/admin(.*)", "destination": "/api/index" },
    { "source": "/uploads/(.*)", "destination": "/api/index" },
    { "source": "/", "destination": "/onlinepaymentplatform-clone-perfect/index.html" },
    { "source": "/(.*)", "destination": "/onlinepaymentplatform-clone-perfect/$1" }
  ]
}
