{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "onlinepaymentplatform-clone-perfect/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/admin(.*)", "dest": "/api/index.js" },
    { "src": "/uploads/(.*)", "dest": "/api/index.js" },
    { "src": "/", "dest": "/onlinepaymentplatform-clone-perfect/index.html" },
    { "src": "/(.*)", "dest": "/onlinepaymentplatform-clone-perfect/$1" }
  ]
}
