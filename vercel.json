{
  "version": 2,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/admin", "destination": "/api/index.js" },
    { "source": "/admin.html", "destination": "/api/index.js" },
    { "source": "/uploads/:path*", "destination": "/api/index.js" },
    { "source": "/:path*", "destination": "/onlinepaymentplatform-clone-perfect/:path*" }
  ]
}
