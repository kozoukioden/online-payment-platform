{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "onlinepaymentplatform-clone-perfect/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/admin",
      "dest": "server.js"
    },
    {
      "src": "/admin.html",
      "dest": "server.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "onlinepaymentplatform-clone-perfect/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "status": 404,
      "dest": "onlinepaymentplatform-clone-perfect/index.html"
    }
  ]
}
